# ─────────────────────────────────────────────────────────
# Resource Guru credentials
# ─────────────────────────────────────────────────────────
RG_CLIENT_ID=

RG_CLIENT_SECRET=

RG_USERNAME=
RG_PASSWORD=

# Your Resource Guru account slug (e.g. from app.resourceguruapp.com/acme-corp → "acme-corp")
RG_ACCOUNT=

# ─────────────────────────────────────────────────────────
# Server config
# ─────────────────────────────────────────────────────────
PORT=

# How often to re-fetch from Resource Guru (milliseconds)
# 900000 = 15 minutes
CACHE_TTL_MS=
