# ─────────────────────────────────────────────────────────
# Resource Guru credentials
# ─────────────────────────────────────────────────────────
RG_CLIENT_ID=your_client_id_here
RG_CLIENT_SECRET=your_client_secret_here
RG_USERNAME=your@email.com
RG_PASSWORD=your_password_here

# Your Resource Guru account slug (e.g. from app.resourceguruapp.com/acme-corp → "acme-corp")
RG_ACCOUNT=your_account_slug

# ─────────────────────────────────────────────────────────
# Anthropic API (for the Claude AI assistant panel)
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─────────────────────────────────────────────────────────
# Server config
# ─────────────────────────────────────────────────────────
PORT=3000

# How often to re-fetch from Resource Guru (milliseconds)
# 900000 = 15 minutes
CACHE_TTL_MS=900000
